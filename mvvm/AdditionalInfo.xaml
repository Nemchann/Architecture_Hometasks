<Window x:Class="MVVM.PhoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подробнее" Height="300" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Модель:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="3"/>

            <TextBlock Text="Страна производства:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="3"/>

            <TextBlock Text="Стоимость:" Margin="0,0,0,5" FontWeight="Bold"/>
            <TextBox Text="{Binding Price, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="3"/>

            <Button Content="OK" IsDefault="True" Click="Accept_Click" Height="30" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
